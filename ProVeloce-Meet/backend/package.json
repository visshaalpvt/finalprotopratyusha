{
    "name": "proveloce-meet-backend",
    "version": "1.0.0",
    "description": "Backend API server for ProVeloce Meet video calling application",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "tsx watch src/server.ts",
        "start:prod": "node dist/server.js",
        "lint": "eslint src --ext .ts",
        "postinstall": "npm run build"
    },
    "dependencies": {
        "@clerk/backend": "^1.0.0",
        "@stream-io/node-sdk": "^0.1.12",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "jose": "^6.1.3",
        "jsonwebtoken": "^9.0.2",
        "jwks-rsa": "^3.2.0",
        "mongoose": "^8.0.3",
        "uuid": "^9.0.1"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.11.5",
        "@types/uuid": "^9.0.8",
        "tsx": "^4.7.1",
        "typescript": "^5.3.3"
    }
}
